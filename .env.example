# =============================================================================
# SniperUser — Configuration
# =============================================================================
# Copie ce fichier en .env et remplis les valeurs.
# Ne commite jamais ton vrai .env (webhook, tokens, etc.).
#
# Crédits : SniperUser — https://github.com/boumco/sniperUser
# Si ce projet t'a été utile, mets une étoile sur le repo pour le soutenir !
# =============================================================================

# URL du webhook Discord pour recevoir les pseudos disponibles (ne pas commiter la vraie valeur)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# Caractères pour générer les pseudos (défaut : a-z + 0-9)
USERNAME_CHARSET=abcdefghijklmnopqrstuvwxyz0123456789

# Longueur min et max des pseudos (recommandé : 3 et 4)
USERNAME_MIN_LENGTH=3
USERNAME_MAX_LENGTH=4

# Délai en secondes entre deux vérifications (éviter le spam API)
SLEEP_BETWEEN_CHECKS=0.2
